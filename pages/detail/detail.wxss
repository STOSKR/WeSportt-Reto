.detail {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.detail-image {
  width: 100%;
  height: 520rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.detail-body {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.category {
  color: #52606d;
  font-size: 24rpx;
  text-transform: uppercase;
}

.title {
  color: #1f2933;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.description,
.rating {
  color: #3e4c59;
  font-size: 28rpx;
  line-height: 1.55;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.primary-button,
.secondary-button,
.retry-button {
  width: 100%;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.primary-button {
  background: #087443;
  color: #ffffff;
}

.secondary-button,
.retry-button {
  background: #1f2933;
  color: #ffffff;
}

.retry-button {
  margin: 20rpx auto 0;
  width: auto;
  font-size: 24rpx;
}

.skeleton-detail .detail-body {
  gap: 18rpx;
}

.skeleton-block {
  position: relative;
  overflow: hidden;
  border-radius: 8rpx;
  background: #e6e9ee;
}

.skeleton-block::after {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(230, 233, 238, 0), rgba(247, 249, 252, 0.86), rgba(230, 233, 238, 0));
  animation: skeleton-shimmer 1.25s ease-out infinite;
  content: "";
  transform: translateX(-100%);
}

.skeleton-hero {
  width: 100%;
  height: 520rpx;
}

.skeleton-line {
  height: 28rpx;
}

.category-line {
  width: 30%;
  height: 22rpx;
}

.title-line {
  width: 92%;
  height: 36rpx;
}

.secondary-title-line {
  width: 72%;
}

.price-line {
  width: 24%;
}

.body-line {
  width: 100%;
}

.short-body-line {
  width: 64%;
}

.skeleton-button {
  width: 100%;
  height: 88rpx;
}

.secondary-button-placeholder {
  opacity: 0.72;
}

@keyframes skeleton-shimmer {
  100% {
    transform: translateX(100%);
  }
}
