.detail {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.detail-image {
  width: 100%;
  height: 520rpx;
  box-sizing: border-box;
  border: 1rpx solid #e1e7df;
  border-radius: 8rpx;
  background: #fbfcf8;
}

.detail-body {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 24rpx;
  border: 1rpx solid #e1e7df;
  border-radius: 8rpx;
  background: #fbfcf8;
  box-shadow: 0 12rpx 28rpx rgba(29, 40, 34, 0.06);
}

.category {
  color: #59665f;
  font-size: 24rpx;
  text-transform: uppercase;
}

.title {
  color: #1d2822;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.description,
.rating {
  color: #3f4c44;
  font-size: 28rpx;
  line-height: 1.55;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.primary-button,
.secondary-button,
.retry-button {
  width: 100%;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.primary-button {
  background: #087443;
  color: #fbfcf8;
}

.secondary-button,
.retry-button {
  background: #1d2822;
  color: #fbfcf8;
}

.retry-button {
  margin: 20rpx auto 0;
  width: auto;
  font-size: 24rpx;
}

.skeleton-detail .detail-body {
  gap: 18rpx;
}

.detail-hero-shell {
  position: relative;
  overflow: hidden;
}

.skeleton-hero {
  width: 100%;
  height: 520rpx;
  border-radius: 7rpx;
}

.hero-loading-chip {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 176rpx;
  height: 54rpx;
  box-sizing: border-box;
  padding: 12rpx;
  border: 1rpx solid rgba(225, 231, 223, 0.78);
  border-radius: 8rpx;
  background: rgba(251, 252, 248, 0.92);
}

.chip-dot {
  width: 26rpx;
  height: 26rpx;
  flex: none;
  border-radius: 50%;
}

.chip-line {
  width: 94rpx;
  height: 18rpx;
}

.skeleton-line {
  height: 28rpx;
}

.category-line {
  width: 30%;
  height: 22rpx;
}

.title-line {
  width: 92%;
  height: 36rpx;
}

.secondary-title-line {
  width: 72%;
}

.price-line {
  width: 24%;
}

.body-line {
  width: 100%;
}

.short-body-line {
  width: 64%;
}

.skeleton-button {
  width: 100%;
  height: 88rpx;
}

.skeleton-actions {
  padding-bottom: 2rpx;
}

.secondary-button-placeholder {
  opacity: 0.72;
}
