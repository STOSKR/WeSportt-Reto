<view class="page">
  <view wx:if="{{successMessageVisible}}" class="success-banner">
    <view class="success-icon">OK</view>
    <text class="success-text">Producto anadido al carrito</text>
  </view>

  <view wx:if="{{loading}}" class="detail skeleton-detail">
    <view class="detail-hero-shell loading-card">
      <view class="skeleton-block skeleton-hero"></view>
      <view class="hero-loading-chip">
        <view class="skeleton-block chip-dot"></view>
        <view class="skeleton-block chip-line"></view>
      </view>
    </view>
    <view class="detail-body loading-card">
      <view class="skeleton-block skeleton-line category-line"></view>
      <view class="skeleton-block skeleton-line title-line"></view>
      <view class="skeleton-block skeleton-line title-line secondary-title-line"></view>
      <view class="skeleton-block skeleton-line price-line"></view>
      <view class="skeleton-block skeleton-line body-line"></view>
      <view class="skeleton-block skeleton-line body-line"></view>
      <view class="skeleton-block skeleton-line body-line short-body-line"></view>
    </view>
    <view class="actions skeleton-actions">
      <view class="skeleton-block skeleton-button"></view>
      <view class="skeleton-block skeleton-button secondary-button-placeholder"></view>
    </view>
  </view>

  <view wx:elif="{{error}}" class="state error">
    <text>{{error}}</text>
    <button class="retry-button" size="mini" bindtap="loadProduct">Reintentar</button>
  </view>

  <view wx:elif="{{product}}" class="detail">
    <image class="detail-image" src="{{product.image}}" mode="aspectFit" />
    <view class="detail-body">
      <text class="category">{{product.category}}</text>
      <text class="title">{{product.title}}</text>
      <text class="price">${{product.price}}</text>
      <text class="description">{{product.description}}</text>
      <text wx:if="{{product.rating}}" class="rating">
        Valoracion: {{product.rating.rate}} / 5 ({{product.rating.count}} reviews)
      </text>
    </view>

    <view class="actions">
      <button class="primary-button" bindtap="addCurrentProductToCart">Anadir al carrito</button>
      <button class="secondary-button" bindtap="goToCart">Ver carrito {{cartCount}}</button>
    </view>
  </view>

  <view wx:if="{{routeLoading}}" class="route-loading-overlay">
    <view class="route-loading-panel">
      <view class="route-loading-ring"></view>
      <view class="route-loading-copy">
        <text class="route-loading-title">Abriendo carrito</text>
        <text class="route-loading-subtitle">Actualizando tus productos</text>
      </view>
    </view>
  </view>
</view>
