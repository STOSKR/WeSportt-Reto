.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.heading {
  font-size: 44rpx;
  font-weight: 700;
}

.cart-button,
.retry-button {
  border-radius: 8rpx;
  background: #1f2933;
  color: #ffffff;
  font-size: 24rpx;
}

.retry-button {
  margin: 20rpx auto 0;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product-card {
  display: flex;
  gap: 20rpx;
  min-height: 188rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(31, 41, 51, 0.08);
}

.product-image {
  width: 148rpx;
  height: 148rpx;
  flex: none;
  background: #ffffff;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-title {
  display: -webkit-box;
  overflow: hidden;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.skeleton-list {
  padding-top: 4rpx;
}

.skeleton-card {
  align-items: center;
}

.skeleton-block {
  position: relative;
  overflow: hidden;
  border-radius: 8rpx;
  background: #e6e9ee;
}

.skeleton-block::after {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(230, 233, 238, 0), rgba(247, 249, 252, 0.86), rgba(230, 233, 238, 0));
  animation: skeleton-shimmer 1.25s ease-out infinite;
  content: "";
  transform: translateX(-100%);
}

.skeleton-image {
  width: 148rpx;
  height: 148rpx;
  flex: none;
}

.skeleton-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-width: 0;
}

.skeleton-line {
  height: 26rpx;
}

.title-line {
  width: 88%;
}

.short-line {
  width: 68%;
}

.price-line {
  width: 28%;
}

@keyframes skeleton-shimmer {
  100% {
    transform: translateX(100%);
  }
}
