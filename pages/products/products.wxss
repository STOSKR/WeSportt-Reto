.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.heading {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.cart-button,
.retry-button {
  border-radius: 8rpx;
  background: #1d2822;
  color: #fbfcf8;
  font-size: 24rpx;
}

.retry-button {
  margin: 20rpx auto 0;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-card {
  display: flex;
  gap: 20rpx;
  min-height: 188rpx;
  padding: 20rpx;
  border: 1rpx solid #e1e7df;
  border-radius: 8rpx;
  background: #fbfcf8;
  box-shadow: 0 12rpx 28rpx rgba(29, 40, 34, 0.06);
}

.product-image {
  width: 148rpx;
  height: 148rpx;
  flex: none;
  border-radius: 8rpx;
  background: #f7f9f4;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-title {
  display: -webkit-box;
  overflow: hidden;
  color: #1d2822;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.skeleton-list {
  padding-top: 2rpx;
}

.loading-brief {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 98rpx;
  padding: 20rpx;
}

.loading-mark {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  flex: none;
  border-radius: 50%;
  background: #e5f3ea;
}

.loading-mark::before {
  position: absolute;
  width: 52rpx;
  height: 52rpx;
  border: 2rpx solid rgba(8, 116, 67, 0.24);
  border-radius: 50%;
  animation: loading-pulse 1.45s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  content: "";
}

.loading-mark-core {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #087443;
}

.loading-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.loading-title {
  color: #1d2822;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.loading-subtitle {
  overflow: hidden;
  color: #59665f;
  font-size: 24rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.skeleton-card {
  align-items: center;
  box-shadow: 0 12rpx 28rpx rgba(29, 40, 34, 0.05);
}

.skeleton-card:nth-child(3n) {
  opacity: 0.92;
}

.skeleton-card:nth-child(4n) {
  opacity: 0.82;
}

.skeleton-image {
  position: relative;
  overflow: hidden;
  width: 148rpx;
  height: 148rpx;
  flex: none;
}

.skeleton-image-dot {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(8, 116, 67, 0.18);
}

.skeleton-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-width: 0;
}

.skeleton-line {
  height: 24rpx;
}

.eyebrow-line {
  width: 34%;
  height: 18rpx;
}

.title-line {
  width: 86%;
  height: 30rpx;
}

.short-line {
  width: 62%;
}

.skeleton-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.price-line {
  width: 96rpx;
}

.skeleton-pill {
  width: 84rpx;
  height: 34rpx;
  border-radius: 999rpx;
}

@keyframes loading-pulse {
  100% {
    opacity: 0;
    transform: scale(1.8);
  }
}
