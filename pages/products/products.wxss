.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.heading {
  font-size: 44rpx;
  font-weight: 700;
}

.cart-button,
.retry-button {
  border-radius: 8rpx;
  background: #1f2933;
  color: #ffffff;
  font-size: 24rpx;
}

.retry-button {
  margin: 20rpx auto 0;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product-card {
  display: flex;
  gap: 20rpx;
  min-height: 188rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 10rpx rgba(31, 41, 51, 0.08);
}

.product-image {
  width: 148rpx;
  height: 148rpx;
  flex: none;
  background: #ffffff;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.product-title {
  display: -webkit-box;
  overflow: hidden;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
