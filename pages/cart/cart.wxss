.cart-page {
  padding-bottom: calc(156rpx + env(safe-area-inset-bottom));
}

.cart-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.header-copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.heading {
  color: #1d2822;
  font-size: 46rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.15;
}

.header-meta {
  color: #59665f;
  font-size: 24rpx;
  line-height: 1.35;
}

.clear-button {
  min-width: 116rpx;
  border: 1rpx solid #efc7c1;
  border-radius: 8rpx;
  background: #fff7f5;
  color: #ad2e23;
  font-size: 24rpx;
  font-weight: 700;
}

.cart-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.cart-summary {
  display: flex;
  gap: 16rpx;
}

.summary-stat {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
  min-height: 86rpx;
  box-sizing: border-box;
  padding: 18rpx 20rpx;
  border: 1rpx solid #e1e7df;
  border-radius: 8rpx;
  background: #fbfcf8;
  box-shadow: 0 10rpx 24rpx rgba(29, 40, 34, 0.05);
}

.summary-label {
  color: #59665f;
  font-size: 22rpx;
  line-height: 1.25;
}

.summary-value {
  color: #1d2822;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.1;
}

.cart-loading-summary {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 98rpx;
  padding: 20rpx;
}

.summary-dot {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  flex: none;
  border-radius: 50%;
  background: #e5f3ea;
}

.summary-dot::after {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #087443;
  box-shadow: 0 0 0 0 rgba(8, 116, 67, 0.22);
  animation: cart-pulse 1.35s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  content: "";
}

.summary-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.summary-title {
  color: #1d2822;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.summary-subtitle {
  overflow: hidden;
  color: #59665f;
  font-size: 26rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border: 1rpx solid #e1e7df;
  border-radius: 8rpx;
  background: #fbfcf8;
  box-shadow: 0 12rpx 28rpx rgba(29, 40, 34, 0.06);
}

.cart-image {
  width: 132rpx;
  height: 132rpx;
  flex: none;
  border-radius: 8rpx;
  background: #f7f9f4;
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-width: 0;
}

.item-topline {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.cart-title {
  display: -webkit-box;
  flex: 1;
  overflow: hidden;
  color: #1d2822;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.32;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.remove-button {
  min-width: 92rpx;
  border: 1rpx solid #e1e7df;
  border-radius: 8rpx;
  background: #f4f6f3;
  color: #59665f;
  font-size: 22rpx;
  font-weight: 700;
}

.item-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  width: 178rpx;
  height: 58rpx;
  overflow: hidden;
  border: 1rpx solid #d7e1d6;
  border-radius: 8rpx;
  background: #f7f9f4;
}

.qty-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  flex: none;
  border-radius: 0;
  background: transparent;
  color: #1d2822;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.quantity-value {
  flex: 1;
  color: #1d2822;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
}

.item-pricing {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  min-width: 128rpx;
}

.unit-price {
  color: #59665f;
  font-size: 22rpx;
  line-height: 1.25;
}

.subtotal-price {
  font-size: 30rpx;
  line-height: 1.2;
}

.checkout-spacer {
  height: 8rpx;
}

.checkout-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  min-height: 108rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #cfe1d3;
  border-radius: 8rpx;
  background: #fbfcf8;
  box-shadow: 0 16rpx 38rpx rgba(29, 40, 34, 0.12);
}

.cart-has-items .checkout-bar {
  position: fixed;
  right: 24rpx;
  bottom: calc(26rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  z-index: 20;
}

.checkout-copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.checkout-label {
  color: #1d2822;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.checkout-note {
  color: #59665f;
  font-size: 22rpx;
  line-height: 1.25;
}

.checkout-total {
  font-size: 38rpx;
  line-height: 1.15;
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
  text-align: left;
}

.empty-title {
  color: #1d2822;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.empty-copy {
  color: #59665f;
  font-size: 26rpx;
  line-height: 1.45;
}

.empty-button,
.secondary-button {
  margin-top: 10rpx;
  width: 100%;
  background: #1d2822;
  color: #fbfcf8;
  font-size: 28rpx;
  font-weight: 700;
}

.cart-skeleton .cart-item,
.cart-skeleton .checkout-bar {
  box-shadow: 0 12rpx 28rpx rgba(29, 40, 34, 0.04);
}

.skeleton-cart-item:nth-child(3) {
  opacity: 0.92;
}

.skeleton-cart-item:nth-child(4) {
  opacity: 0.82;
}

.skeleton-cart-image {
  width: 132rpx;
  height: 132rpx;
  flex: none;
}

.skeleton-cart-info {
  gap: 14rpx;
  justify-content: center;
}

.skeleton-line {
  height: 24rpx;
}

.title-line {
  width: 86%;
  height: 30rpx;
}

.meta-line {
  width: 42%;
}

.price-line {
  width: 92rpx;
}

.total-label-line {
  width: 112rpx;
  height: 30rpx;
}

.total-price-line {
  width: 136rpx;
  height: 34rpx;
}

@keyframes cart-pulse {
  100% {
    box-shadow: 0 0 0 24rpx rgba(8, 116, 67, 0);
  }
}
