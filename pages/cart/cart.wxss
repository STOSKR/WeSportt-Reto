.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.heading {
  font-size: 44rpx;
  font-weight: 700;
}

.clear-button {
  border-radius: 8rpx;
  background: #b42318;
  color: #ffffff;
  font-size: 24rpx;
}

.cart-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 420rpx;
  gap: 18rpx;
  color: #52606d;
}

.spinner {
  width: 54rpx;
  height: 54rpx;
  border: 6rpx solid #d9dee7;
  border-top-color: #1f2933;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  font-size: 26rpx;
}

.cart-content {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.cart-item {
  display: flex;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.cart-image {
  width: 120rpx;
  height: 120rpx;
  flex: none;
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.cart-title {
  display: -webkit-box;
  overflow: hidden;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.cart-meta {
  color: #52606d;
  font-size: 24rpx;
}

.total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

@keyframes spin {
  100% {
    transform: rotate(360deg);
  }
}
