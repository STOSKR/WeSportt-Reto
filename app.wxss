page {
  min-height: 100%;
  background: #f6f7f9;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  margin: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.state {
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #52606d;
  text-align: center;
}

.state.error {
  color: #b42318;
}

.price {
  color: #087443;
  font-weight: 700;
}
